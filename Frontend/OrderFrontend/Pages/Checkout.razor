@page "/checkout"
@inject NavigationManager Nav
@inject OrderFrontend.Services.AuthService Auth
@inject OrderFrontend.Services.CartService CartService
@inject HttpClient Http

<PageTitle>Checkout</PageTitle>

@if (!Auth.IsLoggedIn)
{
    <p>Redirecting...</p>
}
else
{
    <div class="checkout-page">
        <section class="checkout-hero">
            <div>
                <p class="eyebrow">Deals Store</p>
                <h1>Checkout</h1>
                <p>Review your order and place it securely.</p>
            </div>

            <div class="hero-stats">
                <div class="hero-stat">
                    <span>Items</span>
                    <strong>@CartService.TotalItems</strong>
                </div>
                <div class="hero-stat">
                    <span>Total</span>
                    <strong>€@CartService.TotalAmount.ToString("0.00")</strong>
                </div>
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(feedback))
        {
            <div class="info-banner">@feedback</div>
        }

        @if (CartService.Items.Count == 0)
        {
            <section class="state-card">
                <h3>Your cart is empty</h3>
                <p>Add products before continuing to checkout.</p>
                <button class="secondary-btn" @onclick="GoHome">Go to Home</button>
            </section>
        }
        else
        {
            <div class="checkout-layout">
                <section class="checkout-form-card">
                    <h3>Customer Details</h3>

                    <div class="form-grid">
                        <div class="form-group">
                            <label>Full Name</label>
                            <input @bind="customerName" placeholder="Enter your full name" />
                        </div>

                        <div class="form-group">
                            <label>Email</label>
                            <input @bind="customerEmail" type="email" placeholder="Enter your email" />
                        </div>

                        <div class="form-group full-width">
                            <label>Address</label>
                            <input @bind="shippingAddress" placeholder="Enter your shipping address" />
                        </div>

                        <div class="form-group">
                            <label>City</label>
                            <input @bind="city" placeholder="Enter your city" />
                        </div>

                        <div class="form-group">
                            <label>Card Number</label>
                            <input @bind="cardNumber" placeholder="4111 1111 1111 1111" />
                        </div>
                    </div>

                    <div class="checkout-actions">
                        <button class="secondary-btn" @onclick="GoCart">Back to Cart</button>
                        <button class="primary-btn" @onclick="PlaceOrder" disabled="@isSubmitting">
                            @(isSubmitting ? "Processing..." : "Place Order")
                        </button>
                    </div>
                </section>

                <aside class="summary-card">
                    <h3>Order Summary</h3>

                    <div class="summary-items">
                        @foreach (var item in CartService.Items)
                        {
                            <div class="summary-item">
                                <div>
                                    <strong>@item.Name</strong>
                                    <p>Qty: @item.Quantity</p>
                                </div>
                                <span>€@item.LineTotal.ToString("0.00")</span>
                            </div>
                        }
                    </div>

                    <div class="summary-row">
                        <span>Total Items</span>
                        <strong>@CartService.TotalItems</strong>
                    </div>

                    <div class="summary-row total">
                        <span>Total Amount</span>
                        <strong>€@CartService.TotalAmount.ToString("0.00")</strong>
                    </div>
                </aside>
            </div>
        }
    </div>
}

@code {
    private string customerName = string.Empty;
    private string customerEmail = string.Empty;
    private string shippingAddress = string.Empty;
    private string city = string.Empty;
    private string cardNumber = string.Empty;
    private string? feedback;
    private bool isSubmitting;

    private async Task PlaceOrder()
    {
        feedback = null;

        if (string.IsNullOrWhiteSpace(customerName) ||
            string.IsNullOrWhiteSpace(customerEmail) ||
            string.IsNullOrWhiteSpace(shippingAddress) ||
            string.IsNullOrWhiteSpace(city) ||
            string.IsNullOrWhiteSpace(cardNumber))
        {
            feedback = "Please complete all checkout fields.";
            return;
        }

        if (CartService.Items.Count == 0)
        {
            feedback = "Your cart is empty.";
            return;
        }

        isSubmitting = true;

        try
        {
            var response = await Http.PostAsync("http://localhost:5258/api/orders/checkout", null);
            response.EnsureSuccessStatusCode();

            CartService.ClearCart();
            feedback = "Order placed successfully.";
            Nav.NavigateTo("/orders");
        }
        catch (Exception ex)
        {
            feedback = $"Error placing order: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void GoCart()
    {
        Nav.NavigateTo("/cart");
    }

    private void GoHome()
    {
        Nav.NavigateTo("/home");
    }
}