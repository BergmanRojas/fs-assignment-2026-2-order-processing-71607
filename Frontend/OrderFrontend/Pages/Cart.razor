@page "/cart"
@inject NavigationManager Nav
@inject OrderFrontend.Services.AuthService Auth
@inject OrderFrontend.Services.CartService CartService

<PageTitle>Cart</PageTitle>

@if (!Auth.IsLoggedIn)
{
    <p>Redirecting...</p>
}
else
{
    <div class="cart-page">
        <section class="cart-hero">
            <div>
                <p class="eyebrow">Deals Store</p>
                <h1>Your Cart</h1>
                <p>Review your selected products before checkout.</p>
            </div>

            <div class="hero-stats">
                <div class="hero-stat">
                    <span>Items</span>
                    <strong>@CartService.TotalItems</strong>
                </div>
                <div class="hero-stat">
                    <span>Total</span>
                    <strong>€@CartService.TotalAmount.ToString("0.00")</strong>
                </div>
            </div>
        </section>

        @if (CartService.Items.Count == 0)
        {
            <section class="state-card">
                <h3>Your cart is empty</h3>
                <p>Add products from Home to start an order.</p>
                <button class="secondary-btn" @onclick="GoHome">Continue Shopping</button>
            </section>
        }
        else
        {
            <div class="cart-layout">
                <section class="cart-items">
                    @foreach (var item in CartService.Items)
                    {
                        <article class="cart-card">
                            <div class="cart-image-wrap">
                                <img src="@GetCartImage(item)" alt="@item.Name" class="cart-image" />
                            </div>

                            <div class="cart-body">
                                <div class="cart-top">
                                    <div>
                                        <h3>@item.Name</h3>
                                        <p class="cart-price">€@item.Price.ToString("0.00") each</p>
                                    </div>

                                    <button class="remove-btn" @onclick="() => RemoveItem(item.ProductId)">
                                        Remove
                                    </button>
                                </div>

                                <div class="cart-actions">
                                    <div class="qty-box">
                                        <button class="qty-btn" @onclick="() => Decrease(item.ProductId)">−</button>
                                        <span>@item.Quantity</span>
                                        <button class="qty-btn" @onclick="() => Increase(item.ProductId)">+</button>
                                    </div>

                                    <div class="line-total">
                                        €@item.LineTotal.ToString("0.00")
                                    </div>
                                </div>
                            </div>
                        </article>
                    }
                </section>

                <aside class="summary-card">
                    <h3>Order Summary</h3>

                    <div class="summary-row">
                        <span>Total Items</span>
                        <strong>@CartService.Items</strong>
                    </div>

                    <div class="summary-row total">
                        <span>Total Amount</span>
                        <strong>€@CartService.TotalAmount.ToString("0.00")</strong>
                    </div>

                    <button class="primary-btn" @onclick="GoCheckout">
                        Proceed to Checkout
                    </button>

                    <button class="secondary-btn" @onclick="GoHome">
                        Continue Shopping
                    </button>

                    <button class="clear-btn" @onclick="ClearCart">
                        Clear Cart
                    </button>
                </aside>
            </div>
        }
    </div>
}

@code {
    protected override void OnInitialized()
    {
        if (!Auth.IsLoggedIn)
        {
            Nav.NavigateTo("/");
            return;
        }

        CartService.OnChange += HandleCartChanged;
    }

    public void Dispose()
    {
        CartService.OnChange -= HandleCartChanged;
    }

    private void HandleCartChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void Increase(Guid productId)
    {
        CartService.IncreaseQuantity(productId);
    }

    private void Decrease(Guid productId)
    {
        CartService.DecreaseQuantity(productId);
    }

    private void RemoveItem(Guid productId)
    {
        CartService.RemoveItem(productId);
    }

    private void ClearCart()
    {
        CartService.ClearCart();
    }

    private void GoHome()
    {
        Nav.NavigateTo("/home");
    }

    private void GoCheckout()
    {
        Nav.NavigateTo("/checkout");
    }

    private static string GetCartImage(OrderFrontend.Models.CartItem item)
    {
        return string.IsNullOrWhiteSpace(item.ImageUrl)
            ? "data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='320' height='220'><rect width='100%25' height='100%25' fill='%23f6f7fb'/><text x='50%25' y='50%25' dominant-baseline='middle' text-anchor='middle' fill='%23667085' font-family='Arial' font-size='24'>No Image</text></svg>"
            : item.ImageUrl;
    }
}